import { NextRequest, NextResponse } from 'next/server';
import { z } from 'zod';

// Validation schema for chat request
const chatRequestSchema = z.object({
  message: z.string().min(1, 'Message is required'),
  conversationId: z.string().optional(),
});

// Demo responses based on common benefits questions
const getDemoResponse = (message: string): string => {
  const lowerMessage = message.toLowerCase();
  
  // Ignore suggestion text and very short messages
  if (lowerMessage.includes('get answers') || lowerMessage.includes('learn about') || lowerMessage.includes('view your') || lowerMessage.length < 10) {
    return `Hi there! I'm your AmeriVet Benefits AI Assistant. I can help you with:

🎯 **Plan Comparison** - Compare health, dental, and vision plans
💰 **Medical Plan Cost Comparison Tool** - Calculate total annual costs and savings  
📊 **Benefits Dashboard** - View your current enrollment and usage
🏥 **HSA/FSA Info** - Learn about tax-advantaged accounts
📚 **Document Analysis** - Upload and analyze your benefits documents
❓ **General Questions** - Get answers about coverage, claims, and more

This is a demo version, so I'm showing you the interface and capabilities. In production, I'd have access to your actual AmeriVet benefits data and provide personalized, real-time assistance.

What would you like to explore first?`;
  }
  
  // Check for specific questions first (more specific patterns)
  if (lowerMessage.includes('hsa') || lowerMessage.includes('health savings account')) {
    return `Ah, HSAs! One of my favorite topics - these accounts are absolute game-changers for healthcare savings. Let me walk you through why they're so powerful:

**2024 HSA Contribution Limits:**
• Individual: $4,300
• Family: $8,550  
• Catch-up (55+): Additional $1,000

**Why HSAs are so powerful:**
• Pre-tax contributions reduce your taxable income
• Tax-free growth on investments
• Tax-free withdrawals for qualified medical expenses
• It's the only account with this "triple tax advantage"

**To qualify for an HSA, you need:**
• A High Deductible Health Plan (HDHP)
• No other health coverage
• Minimum deductible: $1,600 (individual) / $3,200 (family)
• Maximum out-of-pocket: $8,050 (individual) / $16,100 (family)

**Investment potential:**
Once you reach a minimum balance, many HSAs let you invest in mutual funds, ETFs, and other securities. After age 65, you can use funds for non-medical expenses (though you'll pay income tax on those withdrawals).

Would you like me to help you calculate your optimal HSA contribution or compare HDHP options?`;
  }
  
  if (lowerMessage.includes('dashboard') || lowerMessage.includes('my benefits') || lowerMessage.includes('show me my')) {
    return `Perfect! Let me pull up your personalized benefits dashboard. Here's what I'm seeing:

📊 **Current Enrollment:**
• Health Insurance: Blue Cross Blue Shield PPO
• Dental: Delta Dental Premier  
• Vision: VSP Standard
• Life Insurance: $50,000 coverage
• Disability: Short-term and long-term

💰 **Financial Summary:**
• Monthly Premiums: $487.50
• YTD Healthcare Spending: $2,340
• Remaining Deductible: $1,200
• HSA Balance: $3,450
• FSA Remaining: $890

📅 **Upcoming Deadlines:**
• Open Enrollment: November 1-30, 2024
• HSA Contribution Deadline: December 31, 2024
• FSA Spending Deadline: March 15, 2025

🎯 **Quick Actions:**
• View Detailed Benefits Summary
• Update Dependents
• Change Coverage Level
• Submit Claims
• Find In-Network Providers

📈 **Usage Analytics:**
• Most Used Benefits: Prescription drugs, preventive care
• Cost Trends: 15% increase from last year
• Savings Opportunities: Consider HDHP + HSA

Is there a specific benefit you'd like to explore or update?`;
  }
  
  if (lowerMessage.includes('cost') || lowerMessage.includes('calculator') || lowerMessage.includes('calculate')) {
    return `Great question! The Medical Plan Cost Comparison Tool is one of our most powerful tools. Most people only look at monthly premiums, but the real cost is much more complex. Let me show you:

**Here's what we factor in:**
• Monthly Premiums: Your base monthly cost
• Deductibles: What you pay before insurance kicks in
• Copays & Coinsurance: Your share of covered services
• Out-of-Pocket Maximums: Your maximum annual liability
• HSA Contributions: Tax-advantaged savings potential

**Here's a quick example:**

Plan A (HMO): $400/month + $1,500 deductible = $6,300/year minimum
Plan B (PPO): $600/month + $3,000 deductible = $10,200/year minimum  
Plan C (HDHP): $200/month + $5,000 deductible = $7,400/year minimum

**Key factors to consider:**
• Your expected healthcare usage (preventive, chronic conditions, emergencies)
• Prescription drug needs
• Preferred doctors and hospitals
• Family size and ages
• Employer HSA contributions

I can help you run different scenarios - low, medium, or high healthcare usage - and compare family vs. individual calculations. What's your situation like?`;
  }
  
  if (lowerMessage.includes('compare') || lowerMessage.includes('comparison') || lowerMessage.includes('plans')) {
    return `Excellent! Plan comparison is where most people get overwhelmed, but I'll make it simple. Let me break down the key differences:

**Plan Comparison Matrix:**

| Feature | HMO | PPO | HDHP | EPO |
|---------|-----|-----|------|-----|
| Monthly Premium | $400 | $600 | $200 | $500 |
| Deductible | $1,500 | $3,000 | $5,000 | $2,500 |
| Out-of-Pocket Max | $6,000 | $8,000 | $7,000 | $7,500 |
| Primary Care Visit | $20 copay | $30 copay | 100% until deductible | $25 copay |
| Specialist Visit | $50 copay | $50 copay | 100% until deductible | $50 copay |
| Emergency Room | $200 copay | $500 copay | 100% until deductible | $300 copay |
| Prescription Drugs | $10/$30/$50 | $15/$35/$55 | 100% until deductible | $12/$32/$52 |

**Key questions to ask yourself:**
• Budget: Can you afford higher premiums for lower deductibles?
• Health Status: Do you expect high medical usage?
• Provider Network: Are your preferred doctors covered?
• Flexibility: Do you need referrals or out-of-network options?

Based on your specific situation, I can help you determine which plan type makes the most sense. What's your typical healthcare usage like?`;
  }
  
  if (lowerMessage.includes('health insurance') || lowerMessage.includes('medical plan') || (lowerMessage.includes('coverage') && lowerMessage.length > 15)) {
    return `Health insurance can be confusing, but I'm here to make it clear! Here's what you need to know:

**Plan Types Available:**
• HMO (Health Maintenance Organization) - Lower cost, network restrictions
• PPO (Preferred Provider Organization) - More flexibility, higher cost
• HDHP (High Deductible Health Plan) - Lower premiums, higher deductibles
• EPO (Exclusive Provider Organization) - Network only, no referrals needed

**Key Considerations:**
• Monthly premiums vs. out-of-pocket costs
• Network coverage (doctors, hospitals, specialists)
• Prescription drug coverage
• Mental health and wellness benefits
• Family coverage options

**Medical Plan Cost Comparison Tool Features:**
• Compare total annual costs across plans
• Factor in expected healthcare usage
• Consider HSA/FSA contributions
• Account for employer contributions

Would you like me to help you compare specific plans or calculate costs?`;
  }
  
  // Check for specific advantage/benefit questions
  if (lowerMessage.includes('advantage') || lowerMessage.includes('why use') || lowerMessage.includes('how can you help') || lowerMessage.includes('what are the advantages')) {
    return `That's a great question! A benefits assistant like me can be incredibly valuable. Here's what makes me different:

🎯 **Personalized Guidance**: Get tailored recommendations based on your specific situation, family size, and health needs.

📊 **Plan Comparison**: Easily compare different insurance plans side-by-side with clear cost breakdowns and coverage details.

💰 **Cost Optimization**: Find the most cost-effective options while ensuring you have adequate coverage for your needs.

📚 **Educational Support**: Learn about complex benefits terminology and make informed decisions about your healthcare.

⏰ **Time Savings**: Get instant answers to benefits questions instead of waiting on hold or searching through lengthy documents.

🔍 **Document Analysis**: Upload your benefits documents and get quick summaries and explanations of key terms.

This demo shows the interface - in production, it would connect to your actual benefits data and provide real-time, personalized assistance.`;
  }
  
  // Check for specific Kaiser Oregon Enhanced HMO questions
  if (lowerMessage.includes('oregon enhanced') || lowerMessage.includes('nw oregon enhanced') || lowerMessage.includes('enhanced hmo oregon') || lowerMessage.includes('oregon kaiser enhanced')) {
    return `Excellent choice! The Kaiser Permanente NW Oregon Enhanced HMO is a premium plan with comprehensive coverage. Here's what I can tell you about this specific plan:

**🏥 Kaiser Permanente NW Oregon Enhanced HMO Analysis:**

**Plan Overview:**
• **Coverage Area**: Oregon-specific network
• **Plan Type**: Enhanced HMO (Health Maintenance Organization)
• **Provider Network**: Kaiser Permanente Oregon facilities
• **Coverage Period**: 2024-2025

**Enhanced Benefits (vs Standard):**
• **Lower Copays** - Reduced out-of-pocket costs
• **Expanded Coverage** - More services included
• **Premium Network** - Access to top-tier providers
• **Additional Services** - Wellness programs, preventive care

**Typical Enhanced HMO Features:**
• **Primary Care**: $0-$20 copay
• **Specialist Visits**: $20-$40 copay
• **Emergency Room**: $150-$300 copay
• **Prescription Drugs**: $10-$50 copay tiers
• **Preventive Care**: 100% covered

**Kaiser Permanente Advantages:**
• **Integrated Care** - All services under one roof
• **Electronic Records** - Seamless care coordination
• **Quality Focus** - Evidence-based medicine
• **Member Portal** - Online access to health records

**Cost Considerations:**
• **Higher Premiums** - More expensive than Standard
• **Lower Out-of-Pocket** - Better coverage when you use services
• **No Deductible** - Copay-based system
• **Annual Maximum** - Protection against high costs

**Best For:**
• Oregon residents who want comprehensive coverage
• People who prefer Kaiser's integrated model
• Those who want lower copays and better benefits
• Families who value coordinated care

Would you like me to compare this with the Standard Oregon HMO or discuss the specific benefits in more detail?`;
  }

  // Check for specific Kaiser Washington Enhanced HMO questions
  if (lowerMessage.includes('washington enhanced') || lowerMessage.includes('kp wash enhanced') || lowerMessage.includes('enhanced hmo washington') || lowerMessage.includes('washington kaiser enhanced')) {
    return `Great question about the Kaiser Permanente Washington Enhanced HMO! This is a premium plan with excellent coverage. Here's the detailed breakdown:

**🏥 Kaiser Permanente Washington Enhanced HMO Analysis:**

**Plan Highlights:**
• **Coverage Area**: Washington state network
• **Plan Type**: Enhanced HMO with premium benefits
• **Provider Network**: Kaiser Permanente Washington facilities
• **Coverage Period**: 2024-2025

**Enhanced vs Standard Benefits:**
• **Lower Copays** - Reduced out-of-pocket costs for services
• **Expanded Coverage** - More preventive and wellness services
• **Premium Network** - Access to Kaiser's best providers
• **Additional Benefits** - Enhanced mental health, maternity care

**Typical Coverage Structure:**
• **Office Visits**: $0-$15 copay (vs $20-$30 Standard)
• **Specialist Visits**: $15-$25 copay (vs $30-$50 Standard)
• **Emergency Care**: $100-$200 copay
• **Prescription Drugs**: $5-$25 copay tiers
• **Preventive Services**: 100% covered

**Kaiser Washington Advantages:**
• **Integrated System** - Seamless care coordination
• **Quality Metrics** - High patient satisfaction scores
• **Technology** - Advanced electronic health records
• **Convenience** - Multiple locations across Washington

**Cost Analysis:**
• **Monthly Premium**: Higher than Standard HMO
• **Annual Savings**: Lower copays can save hundreds per year
• **Value Proposition**: Better for frequent healthcare users
• **Family Plans**: Enhanced benefits for dependents

**Network Coverage:**
• **Primary Care**: Extensive network across Washington
• **Specialists**: Full range of medical specialties
• **Hospitals**: Kaiser hospitals and affiliated facilities
• **Urgent Care**: Multiple urgent care centers

Would you like me to compare this with the Washington Standard HMO or discuss the specific cost differences?`;
  }

  // Check for specific Kaiser Washington Standard HMO questions
  if (lowerMessage.includes('washington standard') || lowerMessage.includes('kp wash standard') || lowerMessage.includes('standard hmo washington') || lowerMessage.includes('washington kaiser standard')) {
    return `Perfect! The Kaiser Permanente Washington Standard HMO is a solid, cost-effective option. Here's what you need to know:

**🏥 Kaiser Permanente Washington Standard HMO Analysis:**

**Plan Overview:**
• **Coverage Area**: Washington state network
• **Plan Type**: Standard HMO with essential benefits
• **Provider Network**: Kaiser Permanente Washington facilities
• **Coverage Period**: 2024-2025

**Standard HMO Benefits:**
• **Essential Coverage** - All required health benefits
• **Preventive Care** - 100% covered annual checkups
• **Emergency Care** - Coverage for urgent medical needs
• **Prescription Drugs** - Tiered copay system

**Typical Coverage Structure:**
• **Office Visits**: $20-$30 copay
• **Specialist Visits**: $30-$50 copay
• **Emergency Room**: $200-$400 copay
• **Prescription Drugs**: $10-$50 copay tiers
• **Preventive Services**: 100% covered

**Cost Advantages:**
• **Lower Premiums** - More affordable monthly cost
• **Predictable Costs** - Copay-based system
• **No Deductible** - Pay copays only
• **Annual Maximum** - Protection against high costs

**Kaiser Washington Network:**
• **Primary Care**: Extensive network across Washington
• **Specialists**: Full range of medical specialties
• **Hospitals**: Kaiser hospitals and affiliated facilities
• **Urgent Care**: Multiple urgent care centers

**Best For:**
• Washington residents seeking quality care
• People who want predictable healthcare costs
• Those comfortable with Kaiser's integrated model
• Budget-conscious individuals and families

**Coverage Highlights:**
• **Mental Health**: Comprehensive behavioral health services
• **Maternity Care**: Full pregnancy and delivery coverage
• **Chronic Disease**: Management programs for diabetes, etc.
• **Wellness Programs**: Health education and prevention

Would you like me to compare this with the Washington Enhanced HMO or discuss the specific benefits in more detail?`;
  }

  // Check for specific Kaiser Oregon Standard HMO questions
  if (lowerMessage.includes('oregon standard') || lowerMessage.includes('nw oregon standard') || lowerMessage.includes('standard hmo oregon') || lowerMessage.includes('oregon kaiser standard')) {
    return `Excellent choice! The Kaiser Permanente NW Oregon Standard HMO provides essential coverage at an affordable price. Here's the complete breakdown:

**🏥 Kaiser Permanente NW Oregon Standard HMO Analysis:**

**Plan Overview:**
• **Coverage Area**: Oregon-specific network
• **Plan Type**: Standard HMO with essential benefits
• **Provider Network**: Kaiser Permanente Oregon facilities
• **Coverage Period**: 2024-2025

**Standard HMO Benefits:**
• **Essential Coverage** - All required health benefits
• **Preventive Care** - 100% covered annual checkups
