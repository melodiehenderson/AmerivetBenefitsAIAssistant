# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_EMBEDDINGS_DEPLOYMENT=text-embedding-ada-002

# Azure Cosmos DB Configuration
AZURE_COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
AZURE_COSMOS_KEY=your-cosmos-primary-key
AZURE_COSMOS_DATABASE=benefits-assistant

# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=benefits-documents
AZURE_SEARCH_INDEX=chunks_prod_v1

# Azure Storage Configuration
AZURE_STORAGE_CONNECTION_STRING=USE_KEYVAULT_OR_CI
AZURE_STORAGE_CONTAINER_NAME=documents

# Azure Key Vault (optional - for secret management)
# AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# Azure Functions (optional - for background processing)
# AZURE_FUNCTIONS_ENDPOINT=https://your-functions.azurewebsites.net

# Azure Communication Services (optional - for email/SMS)
# AZURE_COMMUNICATION_CONNECTION_STRING=
# AZURE_COMMUNICATION_EMAIL_FROM=noreply@yourdomain.com
# AZURE_COMMUNICATION_PHONE_NUMBER=+1234567890

# Redis Configuration (for caching and rate limiting)
REDIS_URL=redis://localhost:6379
RATE_LIMIT_REDIS_URL=redis://localhost:6379

# NextAuth Configuration
NEXTAUTH_URL=https://bcgenrolls.com
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
AUTH_TRUST_HOST=true

# Application Security
SHARED_PASSWORD=your-secure-shared-password
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Admin API Tokens
NEXT_PUBLIC_ADMIN_API_TOKEN=demo-admin-token
DEMO_ADMIN_TOKEN=demo-admin-token

# Domain Configuration
DOMAIN_ROOT=bcgenrolls.com
ENVIRONMENT=production

# Feature Flags
FAST_HEALTH=1
ENABLE_ANALYTICS=1
ENABLE_AUDIT_LOGS=1

# Observability
LOG_LEVEL=info
ENABLE_TELEMETRY=1
ENABLE_APP_INSIGHTS=false
# Enrollment destination used by the chatbot CTA
ENROLLMENT_URL=https://amerivetaibot.bcgenrolls.com/subdomain/login
ENROLLMENT_PORTAL_URL=https://wd5.myworkday.com/amerivet/login.htmld
HR_PHONE_NUMBER=888-217-4728

# Application URLs
NEXT_PUBLIC_APP_URL=https://bcgenrolls.com
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_ENROLLMENT_URL=https://amerivetaibot.bcgenrolls.com/subdomain/login

# Router Configuration
# Enable RAG-enhanced routing with document retrieval and validation (recommended for production)
USE_RAG_ROUTER=true
# Enable smart LLM routing (fallback if RAG disabled)
USE_SMART_ROUTER=false
# Model for smart/rag routers
SMART_ROUTER_MODEL=gpt-4o-mini
